# Django Security
SECRET_KEY=your-super-secret-key-at-least-50-characters-long-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_NAME=mental_health_db
DB_USER=root
DB_PASSWORD=Pb@pritam#PB
DB_HOST=localhost# 'db' is the Docker service name; use 'localhost' for local dev
DB_PORT=3306

# Redis (for Django Channels WebSocket support)
REDIS_HOST=redis    # 'redis' is Docker service name; use 'localhost' for local dev

